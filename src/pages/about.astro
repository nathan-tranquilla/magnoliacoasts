---
import { Image } from "astro:assets";
import Main from "../layouts/Main.astro";
import stephAndKids from "../assets/stephAndKids.png";
import potterDavieFam from "../assets/potterDavieFamily.png";
import stephanieCoffee from "../assets/stephCoffee.png";
import Button from "../components/Button.astro";
import { INQUIRE_LINK } from "../data/links";
import SectionHeader from "../components/SectionHeader.astro";
import ExternalLink from "../components/ExternalLink.astro";
import { getCollection } from "astro:content";
import { render } from "astro:content";

let aboutContent = (await getCollection("aboutContent"))[0];
let { Content } = await render(aboutContent);
---

<style is:global>
  article.about p {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  article.about p:first-child {
    font-size: 1.15em;
    line-height: 1.7;
    font-weight: 500;
  }
  article.about p:first-child::first-letter {
    font-size: 2.5em;
    float: left;
    line-height: 1;
    margin-right: 0.1em;
    margin-top: 0.05em;
    font-weight: 600;
    color: var(--color-dark-green);
  }
</style>
<Main
  title="Magnolia Coasts | Mississauga and GTA Photographer"
  description="Meet Stephanie, the photographer behind Magnolia Coasts Photography. Based in Mississauga, she captures timeless family, newborn, and portrait moments."
  keywords="Mississauga photographer, about Magnolia Coasts, Stephanie photographer, portrait photographer GTA, family photographer Mississauga"
  mainClass="bg-[var(--section-bg-color)]"
>
  <SectionHeader title="Photographer" classes="self-center" />
  <article
    aria-label="About the photographer"
    class="about font-cormorant-garamond flex w-screen flex-col items-center justify-start bg-[var(--section-bg-color)] px-4 pb-6 md:pb-16"
  >
    <div class="flex w-full max-w-[1000px] flex-col gap-8">
      <!-- Images + text -->
      <div class="flex flex-col items-start gap-6 md:flex-row md:gap-10">
        <!-- Left: all images stacked -->
        <div class="flex w-full shrink-0 flex-col gap-4 md:w-2/5">
          <div class="shadow-card overflow-hidden rounded-md">
            <Image
              src={stephAndKids}
              alt="Stephanie and the kids."
              priority
              class="h-full w-full object-cover"
            />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="shadow-card overflow-hidden rounded-md">
              <Image
                src={potterDavieFam}
                alt="Potter-Davie family."
                class="h-full w-full object-cover"
              />
            </div>
            <div class="shadow-card overflow-hidden rounded-md">
              <Image
                src={stephanieCoffee}
                alt="Stephanie and coffee."
                class="h-full w-full object-cover"
              />
            </div>
          </div>
        </div>
        <!-- Right: text content -->
        <div class="text-text leading-relaxed md:text-base lg:text-lg">
          <Content />
        </div>
      </div>

      <!-- CTA -->
      <div class="flex justify-center">
        <Button color="Pink" classes="md:text-lg lg:text-xl max-w-[300px]">
          <ExternalLink
            class="flex h-full w-full items-center justify-center"
            href={INQUIRE_LINK}>Book With Stephanie</ExternalLink
          >
        </Button>
      </div>
    </div>
  </article>
</Main>
