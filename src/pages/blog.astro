---
import Main from "../layouts/Main.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) =>
    new Date(b.data.publishDate).getTime() -
    new Date(a.data.publishDate).getTime(),
);
---

<Main title="Blog | Magnolia Coasts Photography">
  <article
    class="bg-default font-cormorant-garamond flex w-screen flex-col items-center justify-start"
  >
    <SectionHeader title="Blog" />
    <div class="flex w-full max-w-[1000px] flex-col gap-6 px-4 pb-12">
      {
        posts.map((post) => (
          <a href={`/blog/${post.id}`} class="no-underline">
            <Card classes="flex-row gap-6 hover:shadow-lg transition-shadow cursor-pointer">
              {post.data.featuredImage && (
                <img
                  src={post.data.featuredImage}
                  alt={post.data.featuredImageAlt || ""}
                  class="hidden h-[160px] w-[240px] rounded object-cover md:block"
                />
              )}
              <div class="flex flex-col gap-2">
                <h2 class="text-xl md:text-2xl">{post.data.title}</h2>
                <time class="text-pastel-green text-sm">
                  {new Date(post.data.publishDate).toLocaleDateString("en-CA", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                {post.data.excerpt && (
                  <p class="text-base leading-relaxed text-gray-600">
                    {post.data.excerpt}
                  </p>
                )}
              </div>
            </Card>
          </a>
        ))
      }
      {
        posts.length === 0 && (
          <p class="py-12 text-center text-lg text-gray-500">
            No posts yet -- check back soon!
          </p>
        )
      }
    </div>
  </article>
</Main>
