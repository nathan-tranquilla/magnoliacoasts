---
import pregnantWoman from "../assets/gallery_index/PregnantWoman.png";
import babyInSling from "../assets/gallery_index/babyInSling2.png";
import familyByRoad from "../assets/gallery_index/FamilyByRoad.png";
import babyBdayCake from "../assets/gallery_index/BabyBDayCake.png";
import babyLookingAtCamera from "../assets/gallery_index/babyLookingAtCamera.jpg";
import childrenInSwing from "../assets/gallery_index/kidsInSwing.png";
import branding from "../assets/gallery_index/womanInOffice.png";
import headshots from "../assets/gallery_index/laughingInChair.png";

import { BASE_URL } from "../data/links";
import Main from "../layouts/Main.astro";
import { Image } from "astro:assets";
import SectionHeader from "../components/SectionHeader.astro";

let galleries = [
  {
    text: "Maternity",
    imgSrc: pregnantWoman,
    href: `${BASE_URL}/gallery/maternity`,
  },
  { text: "Newborn", imgSrc: babyInSling, href: `${BASE_URL}/gallery/newborn` },
  { text: "Family", imgSrc: familyByRoad, href: `${BASE_URL}/gallery/family` },
  {
    text: "Cake Smashes",
    imgSrc: babyBdayCake,
    href: `${BASE_URL}/gallery/cakesmash`,
  },
  {
    text: "Milestones",
    imgSrc: babyLookingAtCamera,
    href: `${BASE_URL}/gallery/milestones`,
  },
  {
    text: "Children",
    imgSrc: childrenInSwing,
    href: `${BASE_URL}/gallery/children`,
  },
  { text: "Branding", imgSrc: branding, href: `${BASE_URL}/gallery/branding` },
  {
    text: "Headshots",
    imgSrc: headshots,
    href: `${BASE_URL}/gallery/headshots`,
  },
];
---

<Main
  title="Magnolia Coasts | Mississauga | Photography Gallery"
  description="Browse photography galleries by Magnolia Coasts — maternity, newborn, family, milestone, headshot, branding, and cake smash sessions in Mississauga."
  keywords="photography gallery Mississauga, maternity photos, newborn photos, family portraits, headshot gallery, branding photography, cake smash photos"
  mainClass="bg-[var(--section-bg-color)]"
>
  <section
    aria-label="Photography galleries"
    class="flex flex-col items-center justify-start bg-[var(--section-bg-color)]"
  >
    <div
      class="stagger-cards grid max-w-[1200px] grid-cols-2 gap-4 self-center p-2 pb-8 md:grid-cols-4"
    >
      <SectionHeader
        title="Galleries"
        classes="col-span-2 md:col-span-4 w-full"
      />
      {
        galleries.map((gallery, i) => (
          <a
            href={gallery.href}
            class="group shadow-card relative w-full max-w-[174px] overflow-hidden rounded-md lg:max-w-[250px]"
          >
            <Image
              src={gallery.imgSrc}
              alt={gallery.text}
              layout="constrained"
              priority={i < 4}
              class="h-full w-full object-cover"
            />
            <div class="absolute inset-x-0 bottom-0 flex items-end justify-center bg-gradient-to-t from-black/70 via-black/30 to-transparent px-2 py-4 opacity-100 transition-opacity duration-300 md:opacity-0 md:group-hover:opacity-100">
              <span class="font-cormorant-garamond text-base font-semibold tracking-wide text-white lg:text-xl">
                {gallery.text}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Main>
