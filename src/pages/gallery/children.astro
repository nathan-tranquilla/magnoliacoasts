---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/children/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Toronto | Children's Photos"
  title="Children"
  description="Capture your child's unique personality with children's photography in your home, at a beautiful outdoor location in the GTA, at a selection of studios in the GTA or at our cozy Mississauga studio. Our sessions are relaxed and engaging, creating authentic portraits full of personality and connection."
  galleryType={GalleryType.Children}
  images={images}
/>
