---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/children/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga | Children's Photos"
  description="Children's photography gallery by Magnolia Coasts in Mississauga. Playful, natural portraits of kids being kids."
  title="Children"
  keywords="children photography Mississauga, kids portraits, child photographer GTA, playful kids photos, children photoshoot"
  galleryType={GalleryType.Children}
  images={images}
/>
