---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/branding/*.webp`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga Branding Photography Gallery"
  title="Mississauga Branding Photography Gallery"
  description="Elevate your business presence with personal branding photography at a selection of studios in the GTA. We create strategic, on-brand imagery that showcases your personality, tells your story, and connects with your ideal audience."
  galleryType={GalleryType.Branding}
  images={images}
/>
