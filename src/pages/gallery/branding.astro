---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/branding/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga | Branding Photos"
  description="Branding photography gallery by Magnolia Coasts in Mississauga. Professional images to elevate your personal brand and business."
  title="Branding"
  galleryType={GalleryType.Branding}
  images={images}
/>
