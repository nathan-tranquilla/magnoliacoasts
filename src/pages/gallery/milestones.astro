---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/milestones/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Toronto | Milestone Photos"
  title="Milestones"
  description="Document every stage of your baby's first year with milestone photography in your home, at a beautiful outdoor location in the GTA, a selection of studios in the GTA or our cozy Mississauga studio. From tummy time to sitting and first steps, we create natural, interactive portraits that highlight your child's growth and personality."
  galleryType={GalleryType.Milestone}
  images={images}
/>
