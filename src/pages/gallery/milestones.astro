---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/milestones/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga | Milestone Photos"
  description="Milestone photography gallery by Magnolia Coasts in Mississauga. Capturing your baby's first smile, sitting, and standing moments."
  title="Milestones"
  keywords="milestone photography Mississauga, baby milestone photos, sitting session, standing session, milestone photographer GTA"
  galleryType={GalleryType.Milestone}
  images={images}
/>
