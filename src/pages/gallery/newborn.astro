---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/newborn/*.webp`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga Newborn Photography Gallery"
  title="Mississauga Newborn Photography Gallery"
  description="Capture your baby's earliest days with professional newborn photography in your home or at our Mississauga studio. Our cozy, baby-led sessions focus on safety, comfort, and creating soft, timeless images you'll cherish forever."
  galleryType={GalleryType.Newborn}
  images={images}
/>
