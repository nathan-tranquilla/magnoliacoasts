---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/newborn/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga | Newborn Photos"
  description="Newborn photography gallery by Magnolia Coasts in Mississauga. Gentle, natural portraits of your baby's first days."
  title="Newborn"
  keywords="newborn photography Mississauga, baby photos, newborn portraits, infant photoshoot, newborn photographer GTA"
  galleryType={GalleryType.Newborn}
  images={images}
/>
