---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/maternity/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga | Maternity Photos"
  description="Maternity photography gallery by Magnolia Coasts in Mississauga. Timeless portraits celebrating your pregnancy journey."
  title="Maternity"
  galleryType={GalleryType.Maternity}
  images={images}
/>
