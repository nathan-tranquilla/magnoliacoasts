---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/maternity/*.webp`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Toronto | Maternity Photos"
  title="Maternity"
  description="Celebrate this beautiful chapter with timeless maternity photography in your home, at a beautiful outdoor location in the GTA, at a selection of studios in the GTA or our cozy Mississauga studio. We specialize in simple, elegant, glowing portraits that capture the connection, anticipation, and beauty of pregnancy."
  galleryType={GalleryType.Maternity}
  images={images}
/>
