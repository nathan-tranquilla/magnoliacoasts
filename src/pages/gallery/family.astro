---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/family/*.webp`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga Family Photography Gallery"
  title="Mississauga Family Photography Gallery"
  description="Preserve meaningful moments with family photography in your home, a beautiful outdoor location in the GTA or at a selection of studios in the GTA. We create warm, natural portraits that reflect your family's connection, love, and personality."
  galleryType={GalleryType.Family}
  images={images}
/>
