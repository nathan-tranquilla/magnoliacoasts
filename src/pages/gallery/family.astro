---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/family/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga | Family Photos"
  description="Family photography gallery by Magnolia Coasts in Mississauga. Beautiful portraits capturing your family's connection and love."
  title="Family"
  keywords="family photography Mississauga, family portraits, outdoor family photos, family photographer GTA, family photoshoot"
  galleryType={GalleryType.Family}
  images={images}
/>
