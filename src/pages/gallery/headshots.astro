---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/headshots/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Toronto | Headshot Photos"
  title="Headshots"
  description="Make a strong first impression with professional headshots at our Mississauga studio. Perfect for business professionals, actors, and entrepreneurs, our sessions deliver polished, modern images that elevate your personal brand."
  galleryType={GalleryType.Headshots}
  images={images}
/>
