---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/cakesmash/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Toronto | Cake Smash Photos"
  title="Cake Smash"
  description="Celebrate your baby's first birthday with fun and memorable cake smash photography at our Mississauga studio or at a beautiful outdoor location in the GTA. We design custom setups and capture every messy, joyful moment in a playful and stress-free session."
  galleryType={GalleryType.CakeSmash}
  images={images}
/>
