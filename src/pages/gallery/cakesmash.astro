---
import Gallery, { GalleryType } from "../../layouts/Gallery.astro";

const images = Object.values(
  import.meta.glob(`../../assets/galleries/cakesmash/*.jpg`, { eager: true }),
).map((module: any) => module.default) as ImageMetadata[];
---

<Gallery
  metaTitle="Mississauga | Cake Smash Photos"
  description="Cake smash and birthday photography gallery by Magnolia Coasts in Mississauga. Fun, colourful sessions for your little one's celebration."
  title="Cake Smash"
  galleryType={GalleryType.CakeSmash}
  images={images}
/>
