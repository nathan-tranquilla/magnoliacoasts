---
import Main from "../layouts/Main.astro";
import Welcome from "../components/Welcome.astro";
import SpecialMoments from "../components/SpecialMoments.astro";
import NewsLetter from "../components/Newsletter.astro";
import ArtInYourHome from "../components/ArtInYourHome.astro";
import HeroSection from "../components/HeroSection.astro";
import Testimonials from "../components/Testimonials.astro";
import {
  buildWebSiteSchema,
  buildReviewSchema,
} from "../utils/structuredData.res.mjs";

const webSiteSchema = buildWebSiteSchema();
const reviewSchema = buildReviewSchema([
  [
    "Erika McNabb",
    "Working with Stephanie was one of the best decisions we ever made! Her easy and friendly manner, professionalism and attention to detail made for a memorable and enjoyable experience. We absolutely love our family photos! Thank you, Stephanie, for capturing beautiful moments that will now become lasting memories.",
    "2023-11",
  ],
  [
    "Nritya Bhumi Studio",
    "Steph is Best baby photographer in town hands down... She was so accommodating and very gentle and thoughtful handling my 10 days old baby. When we arrived at the studio she was waiting for us at the door and greeted us (very welcoming)...during the entire photoshoot she was patient and cool.",
    "2023-08",
  ],
  [
    "Tisha McNama",
    "Stephanie is an extraordinary photographer! She is SO SO good with babies and kids that the photo session seems like a breeze. She takes beautiful and amazing photos. We have been going back to her for 5 years now and we have loved every single sessions and photos. Highly recommended.",
    "2024-05",
  ],
]);
---

<Main
  title="Magnolia Coasts | Mississauga Family & Maternity Photography"
  description="Magnolia Coasts Photography in Mississauga — specializing in family, maternity, newborn, milestone, and headshot photography. Book your session today!"
  keywords="Mississauga photographer, family photography Mississauga, maternity photographer, newborn photography, baby photographer, portrait studio GTA, Toronto family photographer"
  extraSchemas={[webSiteSchema, reviewSchema]}
>
  <HeroSection />
  <Welcome />
  <SpecialMoments />
  <ArtInYourHome />
  <Testimonials />
  <NewsLetter />
</Main>
