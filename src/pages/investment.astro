---
import Main from "../layouts/Main.astro";
import SectionHeader from "../components/SectionHeader.astro";
import InvestmentCard from "../components/InvestmentCard.astro";
import { Image } from "astro:assets";
import { BASE_URL } from "../data/links";

import maternityPackages from "../assets/investment_index/maternityPackages.avif";
import newbornPackages from "../assets/investment_index/newbornPackage.avif";
import milestonePackages from "../assets/investment_index/milestonePackages.avif";
import familyPackages from "../assets/investment_index/familyPackages.avif";
import headshotPackages from "../assets/investment_index/headshotPackages.avif";
import collectionPackages from "../assets/investment_index/collectionPackages.avif";

const investmentCards = [
  {
    href: `${BASE_URL}/investment/maternity`,
    text: "Maternity Packages",
    img: maternityPackages,
    alt: "Pregnant Woman",
  },
  {
    href: `${BASE_URL}/investment/newborn`,
    text: "Newborn Packages",
    img: newbornPackages,
    alt: "Newborn baby",
  },
  {
    href: `${BASE_URL}/investment/milestone`,
    text: "Milestone Packages",
    img: milestonePackages,
    alt: "Baby milestone",
  },
  {
    href: `${BASE_URL}/investment/family`,
    text: "Family Packages",
    img: familyPackages,
    alt: "Family portrait",
  },
  {
    href: `${BASE_URL}/investment/headshot`,
    text: "Headshot Packages",
    img: headshotPackages,
    alt: "Professional headshot",
  },
  {
    href: `${BASE_URL}/investment/collections`,
    text: "Collection Packages",
    img: collectionPackages,
    alt: "Photo collection",
  },
];
---

<Main title="Magnolia Coasts | Mississauga | Photography Investment" description="View photography packages and pricing from Magnolia Coasts — maternity, newborn, family, milestone, headshot, and collection sessions in Mississauga." keywords="photography pricing Mississauga, maternity packages, newborn session cost, family photography rates, headshot pricing, photography investment GTA" mainClass="bg-[var(--section-bg-color)]">
  <section
    aria-label="Photography packages"
    class={`w-full pb-4 box-border w-screen font-cormorant-garamond bg-[var(--section-bg-color)] flex justify-center items-center`}
  >
    <div class="m-2 grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-4 lg:gap-6 max-w-[1200px]">
      <SectionHeader
        title="Investment"
        classes="md:col-span-3 w-full"
      />
      {
        investmentCards.map((card) => (
          <InvestmentCard
            href={card.href}
            text={card.text}
          >
            <Image src={card.img} alt={card.alt} layout="full-width" />
          </InvestmentCard>
        ))
      }
    </div>
  </section>
</Main>
