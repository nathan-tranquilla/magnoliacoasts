---
export interface Props {
  direction: "left" | "right";
  class?: string;
}
const { direction, class: className } = Astro.props;
const rotation = direction === "left" ? "rotate-180" : "";
---

<svg
  class={`h-6 w-6 ${rotation} ${className || ""}`}
  viewBox="0 0 32 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <line x1="2" y1="12" x2="28" y2="12"></line>
  <polyline points="22 6 28 12 22 18"></polyline>
</svg>
