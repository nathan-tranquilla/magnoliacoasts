---
import { Image } from "astro:assets";
import specialMoment1 from "../assets/special_moments/maternity.jpg";
import specialMoment2 from "../assets/special_moments/newborn.jpg";
import specialMoment3 from "../assets/special_moments/family.jpg";
import specialMoment4 from "../assets/special_moments/cake_smash.jpg";
import milestonesImg from "../assets/gallery_index/babyLookingAtCamera.jpg";
import childrenImg from "../assets/gallery_index/kidsInSwing.png";
import brandingImg from "../assets/gallery_index/womanInOffice.png";
import headshotsImg from "../assets/gallery_index/laughingInChair.png";

import SectionTitle from "./SectionTitle.astro";

const mainMoments = [
  {
    text: "Maternity",
    imgSrc: specialMoment1,
    href: "/gallery/maternity",
    alt: "Pregnant Woman",
  },
  {
    text: "Newborn",
    imgSrc: specialMoment2,
    href: "/gallery/newborn",
    alt: "Baby in a sling",
  },
  {
    text: "Family",
    imgSrc: specialMoment3,
    href: "/gallery/family",
    alt: "Family by the road",
  },
  {
    text: "Cake Smashes",
    imgSrc: specialMoment4,
    href: "/gallery/cakesmash",
    alt: "Baby with birthday cake",
  },
];

const otherMoments = [
  {
    text: "Milestones",
    imgSrc: milestonesImg,
    href: "/gallery/milestones",
    alt: "Baby looking at camera",
  },
  {
    text: "Children",
    imgSrc: childrenImg,
    href: "/gallery/children",
    alt: "Children on a swing",
  },
  {
    text: "Branding",
    imgSrc: brandingImg,
    href: "/gallery/branding",
    alt: "Woman in office",
  },
  {
    text: "Headshots",
    imgSrc: headshotsImg,
    href: "/gallery/headshots",
    alt: "Person laughing in chair",
  },
];

const allMoments = [...mainMoments, ...otherMoments];
const mainResolved = allMoments.slice(0, 4);
const otherResolved = allMoments.slice(4);
---

<section
  aria-label="Photo session types"
  id="special_moments"
  class="font-cormorant-garamond grid w-full max-w-[1200px] grid-cols-2 gap-4 self-center px-4 py-6 md:grid-cols-4 md:py-16"
>
  <SectionTitle
    title="What special moments would you like to capture?"
    classStyles="col-span-full"
  />
  {
    mainResolved.map((moment) => (
      <a
        href={moment.href}
        class="group shadow-card relative aspect-[3/4] w-full overflow-hidden rounded-md"
      >
        <Image
          src={moment.imgSrc}
          widths={[200, 300, 400]}
          sizes="(min-width: 768px) 25vw, 50vw"
          alt={moment.alt}
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-x-0 bottom-0 flex items-end justify-center bg-gradient-to-t from-black/70 via-black/30 to-transparent px-2 py-4 opacity-100 transition-opacity duration-300 md:opacity-0 md:group-hover:opacity-100">
          <span class="text-base font-semibold tracking-wide text-white lg:text-xl">
            {moment.text}
          </span>
        </div>
      </a>
    ))
  }
</section>
<section
  aria-label="Other photo session types"
  id="other_special_moments"
  class="font-cormorant-garamond grid w-full max-w-[1200px] grid-cols-2 gap-4 self-center px-4 pb-6 sm:grid-cols-4 md:pb-16"
>
  <SectionTitle
    title="Other types of photo sessions"
    classStyles="col-span-full mt-0 mb-0"
  />
  {
    otherResolved.map((moment) => (
      <a
        href={moment.href}
        class="group shadow-card relative aspect-[3/4] w-full overflow-hidden rounded-md"
      >
        <Image
          src={moment.imgSrc}
          widths={[200, 300, 400]}
          sizes="(min-width: 768px) 25vw, 50vw"
          alt={moment.alt}
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-x-0 bottom-0 flex items-end justify-center bg-gradient-to-t from-black/70 via-black/30 to-transparent px-2 py-4 opacity-100 transition-opacity duration-300 md:opacity-0 md:group-hover:opacity-100">
          <span class="text-base font-semibold tracking-wide text-white lg:text-xl">
            {moment.text}
          </span>
        </div>
      </a>
    ))
  }
</section>
