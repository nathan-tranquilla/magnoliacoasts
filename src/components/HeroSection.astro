---
import { INQUIRE_LINK } from "../data/links";
import ExternalLink from "./ExternalLink.astro";
---

<style>
  .hero-divider {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(57, 44, 44, 0.3) 20%,
      rgba(57, 44, 44, 0.3) 80%,
      transparent
    );
  }
  .hero-divider::before,
  .hero-divider::after {
    content: "\2726";
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(57, 44, 44, 0.3);
    font-size: 0.5rem;
  }
  .hero-divider::before {
    left: -0.75rem;
  }
  .hero-divider::after {
    right: -0.75rem;
  }
</style>

<section
  aria-label="Hero"
  class="flex flex-col bg-gradient-to-r from-[rgb(237,232,220)] to-[rgb(211,208,194)]"
>
  <div
    class="relative flex w-full justify-center overflow-hidden md:max-h-[85vh]"
  >
    <div class="flex w-full max-w-[1800px] items-center justify-center">
      <picture>
        <source
          srcset="/HeroImage.414w.webp 414w, /HeroImage.900w.webp 900w, /HeroImage.1200w.webp 1200w"
          media="(max-width: 414px)"
          sizes="414px"
          type="image/webp"
        />
        <source
          srcset="/HeroImage.600w.webp 600w, /HeroImage.1200w.webp 1200w, /HeroImage.1800w.webp 1800w"
          media="(max-width: 600px)"
          sizes="600px"
          type="image/webp"
        />
        <source
          srcset="/HeroImage.900w.webp 900w, /HeroImage.1800w.webp 1800w"
          media="(max-width: 900px)"
          sizes="900px"
          type="image/webp"
        />
        <source
          srcset="/HeroImage.1200w.webp 1200w, /HeroImage.1800w.webp 1800w"
          media="(max-width: 1200px)"
          sizes="1200px"
          type="image/webp"
        />
        <source
          srcset="/HeroImage.1800w.webp 1800w"
          media="(max-width: 1800px)"
          sizes="1800px"
          type="image/webp"
        />
        <img
          src="/HeroImage.1800w.webp"
          alt="Newborn baby swaddled in pink surrounded by flowers — Magnolia Coasts Photography, Mississauga"
          width="1800"
          height="1286"
          class="md:w-full md:object-cover"
          fetchpriority="high"
        />
      </picture>
    </div>
    <!-- Desktop overlay -->
    <div
      class="hero-overlay absolute bottom-0 hidden flex-col items-center gap-5 rounded-2xl border border-white/20 bg-white/60 px-14 py-10 shadow-xl backdrop-blur-lg md:flex md:-translate-y-14 lg:-translate-y-28"
    >
      <h1
        class="font-cormorant-garamond text-text text-center leading-tight font-light tracking-wide italic md:text-5xl lg:text-6xl"
      >
        Magnolia Coasts Photography
      </h1>
      <div class="hero-divider relative h-px w-28"></div>
      <h2
        class="font-cormorant-garamond text-text/70 text-center font-light tracking-[0.25em] uppercase md:text-base lg:text-lg"
      >
        Family &amp; Newborn Photography in Mississauga
      </h2>
      <ExternalLink
        class="hero-cta font-cormorant-garamond text-text bg-pink/70 border-text/15 hover:bg-pink/90 flex cursor-pointer items-center justify-center rounded-lg border px-10 py-3 tracking-[0.2em] uppercase shadow-md transition-all duration-300 hover:scale-102 hover:shadow-xl focus:scale-102 focus:shadow-xl md:text-base lg:text-lg"
        href={INQUIRE_LINK}>Inquire</ExternalLink
      >
    </div>
  </div>
  <!-- Mobile below image -->
  <div class="flex flex-col items-center gap-2 bg-white px-4 py-4 md:hidden">
    <h1
      class="font-cormorant-garamond text-text text-center text-2xl font-light italic sm:text-3xl"
    >
      Magnolia Coasts Photography
    </h1>
    <h2
      class="font-cormorant-garamond text-text text-center text-sm sm:text-base"
    >
      Family &amp; Newborn Photography in Mississauga
    </h2>
    <ExternalLink
      class="font-cormorant-garamond text-text bg-pink flex cursor-pointer items-center justify-center rounded-lg px-6 py-2 text-sm transition-all hover:scale-102 hover:shadow-md focus:scale-102 focus:shadow-md"
      href={INQUIRE_LINK}>Inquire</ExternalLink
    >
  </div>
</section>
