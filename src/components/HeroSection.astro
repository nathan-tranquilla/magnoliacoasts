---
import { INQUIRE_LINK } from "../data/links";
import ExternalLink from "./ExternalLink.astro";
---

<style>
  .hero-overlay {
    corner-shape: notch;
  }
  .hero-cta {
    corner-shape: notch;
  }
</style>

<section
  aria-label="Hero"
  class="flex flex-col bg-gradient-to-r from-[rgb(237,232,220)] to-[rgb(211,208,194)]"
>
  <div class="relative flex w-full justify-center md:max-h-[85vh] overflow-hidden">
    <div class="flex w-full max-w-[1800px] items-center justify-center">
      <picture>
        <source
          srcset="/HeroImage.414w.webp"
          media="(max-width: 414px)"
          type="image/webp"
        />
        <source
          srcset="/HeroImage.600w.webp"
          media="(max-width: 600px)"
          type="image/webp"
        />
        <source
          srcset="/HeroImage.900w.webp"
          media="(max-width: 900px)"
          type="image/webp"
        />
        <source
          srcset="/HeroImage.1800w.webp"
          media="(max-width: 1800px)"
          type="image/webp"
        />
        <img
          src="/HeroImage.1800w.webp"
          alt="Newborn baby swaddled in pink surrounded by flowers — Magnolia Coasts Photography, Mississauga"
          width="1800"
          height="861"
          class="md:object-cover md:w-full"
          fetchpriority="high"
        />
      </picture>
    </div>
    <!-- Desktop overlay -->
    <div class="hero-overlay hidden md:flex absolute bottom-0 flex-col items-center gap-4 lg:-translate-y-28 md:-translate-y-14 rounded-2xl border border-white/30 bg-white/50 backdrop-blur-md px-12 py-8 shadow-lg">
      <h1 class="font-cormorant-garamond italic font-light text-[#392C2C] text-center md:text-5xl lg:text-6xl tracking-wide">
        Magnolia Coasts Photography
      </h1>
      <div class="h-px w-24 bg-[#392C2C]/30"></div>
      <h2 class="font-cormorant-garamond text-[#392C2C]/80 text-center md:text-lg lg:text-xl tracking-widest uppercase">
        Family &amp; Newborn Photography in Mississauga
      </h2>
      <ExternalLink
        class="hero-cta font-cormorant-garamond text-[#392C2C] md:text-lg lg:text-xl tracking-wider flex justify-center items-center cursor-pointer rounded-lg bg-pink/80 border border-pink px-8 py-2.5 transition-all hover:scale-102 focus:scale-102 hover:shadow-md focus:shadow-md hover:bg-pink"
        href={INQUIRE_LINK}>Inquire</ExternalLink
      >
    </div>
  </div>
  <!-- Mobile below image -->
  <div class="flex md:hidden flex-col items-center gap-2 px-4 py-4">
    <h1 class="font-cormorant-garamond italic font-light text-[#392C2C] text-center text-2xl sm:text-3xl">
      Magnolia Coasts Photography
    </h1>
    <h2 class="font-cormorant-garamond text-[#392C2C] text-center text-sm sm:text-base">
      Family &amp; Newborn Photography in Mississauga
    </h2>
    <ExternalLink
      class="font-cormorant-garamond text-[#392C2C] text-sm flex justify-center items-center cursor-pointer rounded-lg bg-pink px-6 py-2 transition-all hover:scale-102 focus:scale-102 hover:shadow-md focus:shadow-md"
      href={INQUIRE_LINK}>Inquire</ExternalLink
    >
  </div>
</section>
