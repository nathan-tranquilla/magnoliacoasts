---
import Card from "./Card.astro";
import Button from "./Button.astro";
import InvestmentHeader from "./InvestmentHeader.astro";
import ExternalLink from "./ExternalLink.astro";

export interface Props {
  cardStyle?: string;
  title: string;
  details: string[];
  price?: number;
  priceRange?: string;
  productLink: string;
}
let { title, details, price, priceRange, cardStyle, productLink } = Astro.props;
---

<style>
  li::marker {
    color: var(--color-pink);
  }
</style>
<Card
  test_id={title}
  as="article"
  classes={`w-full max-w-[400px] m-2 ${cardStyle || ""}`}
>
  <InvestmentHeader title={title} />
  <slot />
  <ul
    class="font-cormorant-garamond my-2 flex list-inside list-disc flex-col items-start justify-start"
  >
    {
      details
        .filter((detail) => detail.length > 0)
        .map((detail: string) => (
          <li class="my-[0.25rem] align-middle text-lg">{detail}</li>
        ))
    }
  </ul>
  <div class="border-border mt-auto flex flex-col gap-3 border-t pt-4">
    <div class="font-cormorant-garamond text-center text-xl font-bold">
      ${price || priceRange} + Tax
    </div>
    <Button color="Pink" classes="w-full max-w-full py-3">
      <ExternalLink
        href={productLink}
        class="font-cormorant-garamond flex h-full w-full items-center justify-center text-lg"
        >Inquire</ExternalLink
      >
    </Button>
  </div>
</Card>
