<script is:inline>
  // Defer GA loading until after page render
  window.gtag =
    window.gtag ||
    function () {
      console.log("gtag called (disabled):", arguments);
    };

  function loadGA() {
    if (window.location.hostname.match(/^(localhost|127\.0\.0\.1)$/)) {
      console.log("Google Analytics disabled on localhost");
      return;
    }
    var script = document.createElement("script");
    script.async = true;
    script.src = "https://www.googletagmanager.com/gtag/js?id=G-L4MNKNZVNM";
    document.head.appendChild(script);

    window.dataLayer = window.dataLayer || [];
    window.gtag = function () {
      dataLayer.push(arguments);
    };
    window.gtag("js", new Date());
    window.gtag("config", "G-L4MNKNZVNM");
  }

  // Load after page is interactive
  if ("requestIdleCallback" in window) {
    requestIdleCallback(loadGA);
  } else {
    setTimeout(loadGA, 3000);
  }
</script>
