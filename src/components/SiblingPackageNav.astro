---
import FAButton from "./FAButton.astro";
export enum NavDir {
  Left = "left",
  Right = "right",
}
export interface Props {
  direction: NavDir;
  text: string;
  href: string;
}
const { direction, text, href } = Astro.props;
const desktopDisplay = "hidden md:flex justify-center items-center";
const mobileDisplay = `md:hidden flex ${direction == NavDir.Left ? "justify-start" : "justify-end"} items-center`;
const overflowDisplay =
  "h-fit whitespace-nowrap overflow-hidden text-ellipsis font-cormorant-garamond";
const textDisplay = "block vertical-middle text-center";
---

<a
  id={direction == NavDir.Left ? "prev-desktop" : "next-desktop"}
  href={href}
  aria-label={`${direction == NavDir.Left ? "Previous" : "Next"}: ${text}`}
  class={`w-[20vw] px-4 ${desktopDisplay}`}
>
  {
    direction == NavDir.Left && (
      <FAButton title={"Previous Page"} direction="left" />
    )
  }
  <span
    class={`${overflowDisplay} ${textDisplay} mx-2 text-base md:text-xl font-semibold`}
    >{text}</span
  >
  {direction == NavDir.Right && <FAButton title={"Next Page"} direction="right" />}
</a>
<a
  id={direction == NavDir.Left ? "prev-mobile" : "next-mobile"}
  href={href}
  aria-label={`${direction == NavDir.Left ? "Previous" : "Next"}: ${text}`}
  class={`w-[20vw] ${mobileDisplay} `}
>
  <span class="sr-only">{text}</span>
  <FAButton
    title={direction == NavDir.Left ? "Previous Page" : "Next Page"}
    direction={direction == NavDir.Left ? "left" : "right"}
    classes="max-h-[2rem] max-w-[2rem]"
  />
</a>
