---
import { Image } from "astro:assets";
import artInYourHome from "../assets/ArtInYourHome.avif";
---

<div
  class="relative flex justify-center bg-gradient-to-r from-[rgb(230,229,236)] to-[rgb(153,148,149)]"
>
  <Image
    src={artInYourHome}
    alt="Art in your home — framed photography prints"
    widths={[414, 600, 900, 1200, 1800]}
    sizes="100vw"
    quality={95}
    loading="lazy"
  />
  <div
    class="font-cormorant-garamond bg-pink/50 absolute right-0 bottom-0 left-0 flex items-center justify-end px-4 py-4 text-3xl text-white md:px-8 lg:px-12 lg:text-5xl"
  >
    Art In Your Home
  </div>
</div>
