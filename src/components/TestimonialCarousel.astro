---
import { getImage } from "astro:assets";
import { make as Carousel } from "./Carousel.res.mjs";
import SectionTitle from "./SectionTitle.astro";
import SplotchyBackground from "./SplotchyBackground.astro";

import erikaSrc from "../assets/testimonials/erika.jpg";
import nrityaSrc from "../assets/testimonials/nritya.jpg";
import tishaSrc from "../assets/testimonials/tisha.jpg";

const erika = await getImage({ src: erikaSrc });
const nritya = await getImage({ src: nrityaSrc });
const tisha = await getImage({ src: tishaSrc });
---

<SplotchyBackground
  aria-label="Client testimonials"
  classes="carousel w-dvw flex flex-col justify-center items-center py-6 md:py-16 testimonials"
>
  <SectionTitle title="What our clients say about us" />
  <Carousel client:load images={[erika.src, nritya.src, tisha.src]} />
</SplotchyBackground>
