---
import { getImage } from "astro:assets";
import Button from "../components/Button.astro";
import stephaniePortrait from "../assets/StephaniePortrait.png";
import { BASE_URL } from "../data/links";
import SplotchyBackground from "./SplotchyBackground.astro";
import { getCollection, render } from "astro:content";

let welcomeContent = (await getCollection("welcomeContent"))[0];
let { Content } = await render(welcomeContent);
const portrait = await getImage({ src: stephaniePortrait });
---

<SplotchyBackground aria-label="Welcome" classes="py-6 md:py-16">
  <!-- Mobile: float layout -->
  <div class="w-full max-w-[1200px] px-4 md:hidden">
    <div
      class="font-cormorant-garamond text-text rounded-xl bg-white/60 p-4 text-sm shadow-sm backdrop-blur-md"
    >
      <img
        src={portrait.src}
        width="333"
        height="500"
        alt="A portrait of Stephanie, the owner of Magnolia Coasts Photography."
        class="shadow-card float-left mr-3 mb-2 w-24 rounded-md object-cover sm:w-32"
        loading="lazy"
      />
      <h2 class="text-lg font-bold">{welcomeContent.data.title}</h2>
      <div class="leading-relaxed">
        <Content />
      </div>
      <div class="clear-left flex justify-center pt-2">
        <Button color="Mint" classes="font-cormorant-garamond">
          <a
            href={`${BASE_URL}/about`}
            class="flex h-full w-full items-center justify-center">About Me</a
          >
        </Button>
      </div>
    </div>
  </div>

  <!-- Desktop: side-by-side -->
  <div
    class="hidden w-full max-w-[1200px] flex-row items-center gap-12 px-4 md:flex"
  >
    <div
      class="shadow-card w-80 shrink-0 overflow-hidden rounded-md"
      style="aspect-ratio: 333/500;"
    >
      <img
        src={portrait.src}
        width="333"
        height="500"
        alt="A portrait of Stephanie, the owner of Magnolia Coasts Photography."
        class="h-full w-full object-cover"
      />
    </div>
    <div
      class="font-cormorant-garamond text-text flex flex-col items-start gap-4 rounded-xl bg-white/60 p-8 text-left text-lg shadow-sm backdrop-blur-md"
    >
      <h2 class="text-3xl font-bold">{welcomeContent.data.title}</h2>
      <div class="leading-relaxed">
        <Content />
      </div>
      <Button color="Mint" classes="font-cormorant-garamond">
        <a
          href={`${BASE_URL}/about`}
          class="flex h-full w-full items-center justify-center">About Me</a
        >
      </Button>
    </div>
  </div>
</SplotchyBackground>
