---
import { getCollection } from "astro:content";
import Main from "../layouts/Main.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { render } from "astro:content";
import {
  get_surrounding_pkgs,
  getPackageLink,
  getPackageTuple,
  allPackageTuples,
  extractPrices,
} from "./InvestmentPackage.res.mjs";
import SiblingPackageNav, {
  NavDir,
} from "../components/SiblingPackageNav.astro";
import StandardInvestment from "../components/StandardInvestment.astro";
import CollectionsInvestment from "../components/CollectionsInvestment.astro";
import { buildServiceSchema } from "../utils/structuredData.res.mjs";
import { BASE_URL } from "../data/links";

export enum PackageType {
  Maternity = "maternityPackages",
  Newborn = "newbornPackages",
  Milestone = "milestonePackages",
  Family = "familyPackages",
  Headshot = "headshotPackages",
  Collections = "collectionsPackages",
}

const investmentIntro: Record<
  PackageType,
  { text: string; cta?: [string, string] }
> = {
  [PackageType.Maternity]: {
    text: "Celebrate your pregnancy journey with a maternity photography session in our Mississauga studio or at a scenic outdoor location.",
    cta: ["View Maternity Gallery", `${BASE_URL}/gallery/maternity`],
  },
  [PackageType.Newborn]: {
    text: "Welcome your newest family member with a gentle newborn session, best booked for babies under 14 days old in our warm Mississauga studio.",
    cta: ["View Newborn Gallery", `${BASE_URL}/gallery/newborn`],
  },
  [PackageType.Milestone]: {
    text: "Capture your baby's growth with milestone sessions at 3, 6, and 9 months, each tailored to your baby's personality.",
    cta: ["View Milestone Gallery", `${BASE_URL}/gallery/milestones`],
  },
  [PackageType.Family]: {
    text: "Create lasting memories with a family photography session in Mississauga — indoor studio and outdoor locations available.",
    cta: ["View Family Gallery", `${BASE_URL}/gallery/family`],
  },
  [PackageType.Headshot]: {
    text: "Professional headshot and branding photography for corporate professionals, entrepreneurs, and creatives in the Greater Toronto Area.",
    cta: ["View Headshot Gallery", `${BASE_URL}/gallery/headshots`],
  },
  [PackageType.Collections]: {
    text: "Save with our bundled photography collections combining maternity, newborn, and family sessions at a discounted rate.",
  },
};

export interface Props {
  pkgType: PackageType;
  title: string;
  description: string;
  keywords?: string;
}

let { pkgType, title, description, keywords } = Astro.props;

const pkg = getPackageTuple(pkgType);
const link = getPackageLink(pkgType);
let pkgs = get_surrounding_pkgs(pkg, allPackageTuples);

const collection = (await getCollection(pkgType)).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
);

const desktopDisplay = "md:grid grid-cols-[20vw_50vw_20vw] gap-2";
const mobileDisplay = "flex justify-around items-center";

const prices = extractPrices(
  collection.map((p) => ({
    price: p.data.price,
    priceRange: (p.data as any).priceRange,
  })),
);
const serviceSchema = buildServiceSchema(title, Astro.url.pathname, prices);
---

<Main
  title={`Magnolia Coasts | Mississauga | ${title}`}
  description={description}
  keywords={keywords}
  extraSchemas={[serviceSchema]}
>
  <section
    aria-label={`${title} navigation`}
    class={`self-center ${desktopDisplay} ${mobileDisplay}`}
  >
    <SiblingPackageNav
      text={pkgs[0][0]}
      href={pkgs[0][1]}
      direction={NavDir.Left}
    />
    <SectionHeader title={title} />
    <SiblingPackageNav
      text={pkgs[1][0]}
      href={pkgs[1][1]}
      direction={NavDir.Right}
    />
  </section>
  <p
    class="font-cormorant-garamond max-w-[800px] self-center px-6 py-4 text-center text-lg text-gray-700"
  >
    {investmentIntro[pkgType].text}
    {
      investmentIntro[pkgType].cta && (
        <a
          href={investmentIntro[pkgType].cta![1]}
          class="text-dark-green ml-1 font-semibold underline decoration-1 underline-offset-2 hover:text-green-900"
        >
          {investmentIntro[pkgType].cta![0]} &rarr;
        </a>
      )
    }
  </p>
  <section
    aria-label={`${title} options`}
    class="flex w-full flex-wrap items-stretch justify-center p-4"
  >
    {
      collection.map(async (pkg) => {
        let { Content } = await render(pkg);
        switch (pkgType) {
          case PackageType.Collections:
            return (
              <CollectionsInvestment
                photoCount={pkg.data.photoCount}
                title={pkg.data.title}
                price={pkg.data.price}
                priceDetails={pkg.data.priceDetails}
                detailsCollection={pkg.data.detailsCollection}
                productLink={pkg.data.productLink}
              >
                <Content />
              </CollectionsInvestment>
            );
          default:
            return (
              <StandardInvestment
                cardStyle={pkg.data.cardStyle}
                title={pkg.data.title}
                price={pkg.data.price}
                priceRange={pkg.data.priceRange}
                details={pkg.data.details}
                productLink={pkg.data.productLink}
              >
                <Content />
              </StandardInvestment>
            );
        }
      })
    }
  </section>
</Main>
