---
import { Image } from "astro:assets";
import Main from "./Main.astro";
import type { ImageMetadata } from "astro";
import { BASE_URL } from "../data/links";
import { get_surrounding_pkgs } from "./InvestmentPackage.res.mjs";
import SiblingPackageNav, {
  NavDir,
} from "../components/SiblingPackageNav.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { make as FloatingCta } from "../components/FloatingCta.res.mjs";

export enum GalleryType {
  Maternity = "maternity",
  Newborn = "newborn",
  Milestone = "milestone",
  CakeSmash = "cakesmash",
  Family = "family",
  Children = "children",
  Branding = "branding",
  Headshots = "headshots",
}

const galleryTypeToTuple: Record<GalleryType, [string, string]> = {
  [GalleryType.Maternity]: ["Maternity", `${BASE_URL}/gallery/maternity`],
  [GalleryType.Newborn]: ["Newborn", `${BASE_URL}/gallery/newborn`],
  [GalleryType.Milestone]: ["Milestone", `${BASE_URL}/gallery/milestones`],
  [GalleryType.CakeSmash]: [
    "Cake Smash & Birthday",
    `${BASE_URL}/gallery/cakesmash`,
  ],
  [GalleryType.Family]: ["Family", `${BASE_URL}/gallery/family`],
  [GalleryType.Children]: ["Children", `${BASE_URL}/gallery/children`],
  [GalleryType.Branding]: ["Branding", `${BASE_URL}/gallery/branding`],
  [GalleryType.Headshots]: ["Headshots", `${BASE_URL}/gallery/headshots`],
};

const desktopDisplay = "md:grid grid-cols-[20vw_50vw_20vw] gap-2";
const mobileDisplay = "flex justify-around items-center";

export interface Props {
  title: string;
  metaTitle: string;
  description?: string;
  images: ImageMetadata[];
  galleryType: GalleryType;
}
const { metaTitle, title, description, galleryType, images } = Astro.props;

const galleryTypeToInvestment: Record<GalleryType, [string, string]> = {
  [GalleryType.Maternity]: ["View Maternity Packages", `${BASE_URL}/investment/maternity`],
  [GalleryType.Newborn]: ["View Newborn Packages", `${BASE_URL}/investment/newborn`],
  [GalleryType.Milestone]: ["View Milestone Packages", `${BASE_URL}/investment/milestone`],
  [GalleryType.CakeSmash]: ["View Milestone Packages", `${BASE_URL}/investment/milestone`],
  [GalleryType.Family]: ["View Family Packages", `${BASE_URL}/investment/family`],
  [GalleryType.Children]: ["View Family Packages", `${BASE_URL}/investment/family`],
  [GalleryType.Headshots]: ["View Headshot Packages", `${BASE_URL}/investment/headshot`],
  [GalleryType.Branding]: ["View Headshot Packages", `${BASE_URL}/investment/headshot`],
};
const investmentLink = galleryTypeToInvestment[galleryType];

let galleries = Object.values(galleryTypeToTuple);
const pkg = galleryTypeToTuple[galleryType];
let pkgs = get_surrounding_pkgs(pkg, galleries);

const sortByFilename = (a: ImageMetadata, b: ImageMetadata) => {
  // Extract the numeric part from the filename (e.g., '01' from '01.jpg')
  const numA = parseInt(a.src.match(/(\d+)/)?.[0] || "0", 10);
  const numB = parseInt(b.src.match(/(\d+)/)?.[0] || "0", 10);
  return numA - numB;
};
const sortedImages = images.sort(sortByFilename);
let getDimensions = (i: number, galleryType: GalleryType) => {
  let mod;
  let isLandscape;
  let classes;
  switch (galleryType) {
    case GalleryType.Maternity:
    case GalleryType.Newborn:
    case GalleryType.Milestone:
    case GalleryType.CakeSmash:
    case GalleryType.Family:
    case GalleryType.Children:
    case GalleryType.Branding:
      mod = i % 4;
      isLandscape = mod == 0 || mod == 3;
      classes = `${isLandscape ? "xs:col-span-2" : "xs:col-span-1"} col-span-1`;
      break;
    case GalleryType.Headshots:
      mod = i % 15;
      isLandscape = mod == 4 || mod == 5 || mod == 13;
      classes = `${isLandscape ? "xs:col-span-2" : "xs:col-span-1"} col-span-1`;
      break;
  }
  return {
    width: isLandscape ? 730 : 357,
    height: 500,
    classes: classes,
  };
};
---

<Main title={`Magnolia Coasts | ${metaTitle}`}>
  <div class={`self-center ${desktopDisplay} ${mobileDisplay}`}>
    <SiblingPackageNav
      text={pkgs[0][0]}
      href={pkgs[0][1]}
      direction={NavDir.Left}
    />
    <SectionHeader title={title} />
    <SiblingPackageNav
      text={pkgs[1][0]}
      href={pkgs[1][1]}
      direction={NavDir.Right}
    />
  </div>
  {description && (
    <h2 class="px-4 mb-8 text-left text-sm md:text-lg text-black lg:max-w-[1200px] self-center font-normal">
      {description}{investmentLink && (
        <>{" "}<a href={investmentLink[1]} class="underline hover:opacity-80">{investmentLink[0]}</a></>
      )}
    </h2>
  )}
<div
    class=`xs:grid-cols-3 grid grid-cols-1 gap-4 self-center p-4 lg:max-w-[1200px]`
  >
    {
      sortedImages.map((image: ImageMetadata, i) => {
        const { width, height, classes } = getDimensions(i, galleryType);
        return (
          <div id={`image-${i}`} class={classes}>
            <Image
              style="content-visibility: auto"
              src={image}
              layout="full-width"
              width={width}
              height={height}
              class="h-[100%] object-cover object-center"
              alt={`Gallery image-${i} for ${title}`}
              decoding="async"
              loading={i < 6 ? "eager" : "lazy"}
            />
          </div>
        );
      })
    }
  </div>
  {investmentLink && (
    <FloatingCta
      client:idle
      href={investmentLink[1]}
      label={investmentLink[0]}
    />
  )}
</Main>
