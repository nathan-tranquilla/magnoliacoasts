---
import { Image } from "astro:assets";
import Main from "./Main.astro";
import type { ImageMetadata } from "astro";
import { BASE_URL } from "../data/links";
import { get_surrounding_pkgs } from "./InvestmentPackage.res.mjs";
import SiblingPackageNav, {
  NavDir,
} from "../components/SiblingPackageNav.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { buildImageGallerySchema } from "../utils/structuredData.res.mjs";
import { make as FloatingCta } from "../components/FloatingCta.res.mjs";

export enum GalleryType {
  Maternity = "maternity",
  Newborn = "newborn",
  Milestone = "milestone",
  CakeSmash = "cakesmash",
  Family = "family",
  Children = "children",
  Branding = "branding",
  Headshots = "headshots",
}

const galleryTypeToTuple: Record<GalleryType, [string, string]> = {
  [GalleryType.Maternity]: ["Maternity", `${BASE_URL}/gallery/maternity`],
  [GalleryType.Newborn]: ["Newborn", `${BASE_URL}/gallery/newborn`],
  [GalleryType.Milestone]: ["Milestone", `${BASE_URL}/gallery/milestones`],
  [GalleryType.CakeSmash]: [
    "Cake Smash & Birthday",
    `${BASE_URL}/gallery/cakesmash`,
  ],
  [GalleryType.Family]: ["Family", `${BASE_URL}/gallery/family`],
  [GalleryType.Children]: ["Children", `${BASE_URL}/gallery/children`],
  [GalleryType.Branding]: ["Branding", `${BASE_URL}/gallery/branding`],
  [GalleryType.Headshots]: ["Headshots", `${BASE_URL}/gallery/headshots`],
};

const galleryIntro: Record<
  GalleryType,
  { text: string; cta?: [string, string] }
> = {
  [GalleryType.Maternity]: {
    text: "Elegant studio and outdoor maternity sessions in Mississauga, celebrating the beauty of pregnancy with soft, natural light and timeless poses.",
    cta: ["View Maternity Packages", `${BASE_URL}/investment/maternity`],
  },
  [GalleryType.Newborn]: {
    text: "Gentle, natural newborn portraits captured during baby's first days in our warm, safe Mississauga studio.",
    cta: ["View Newborn Packages", `${BASE_URL}/investment/newborn`],
  },
  [GalleryType.Milestone]: {
    text: "Milestone photography capturing your baby's personality and growth at 3, 6, and 9 months in our Mississauga studio.",
    cta: ["View Milestone Packages", `${BASE_URL}/investment/milestone`],
  },
  [GalleryType.CakeSmash]: {
    text: "Colourful, fun cake smash and first birthday sessions capturing your little one's milestone celebration in our Mississauga studio.",
  },
  [GalleryType.Family]: {
    text: "Natural, candid family moments in beautiful Mississauga locations — from playful park sessions to intimate studio portraits.",
    cta: ["View Family Packages", `${BASE_URL}/investment/family`],
  },
  [GalleryType.Children]: {
    text: "Playful, natural portraits of children in beautiful settings around Mississauga, capturing their unique personality and spirit.",
  },
  [GalleryType.Branding]: {
    text: "Professional lifestyle and brand imagery for entrepreneurs and small businesses in the Greater Toronto Area.",
    cta: [
      "View Headshot & Branding Packages",
      `${BASE_URL}/investment/headshot`,
    ],
  },
  [GalleryType.Headshots]: {
    text: "Polished studio headshot portraits for corporate professionals, actors, and creatives in Mississauga.",
    cta: ["View Headshot Packages", `${BASE_URL}/investment/headshot`],
  },
};

const desktopDisplay = "md:grid grid-cols-[20vw_50vw_20vw] gap-2";
const mobileDisplay = "flex justify-around items-center";

export interface Props {
  title: string;
  metaTitle: string;
  description: string;
  keywords?: string;
  images: ImageMetadata[];
  galleryType: GalleryType;
}
const { metaTitle, title, description, keywords, galleryType, images } =
  Astro.props;
let galleries = Object.values(galleryTypeToTuple);
const pkg = galleryTypeToTuple[galleryType];
let pkgs = get_surrounding_pkgs(pkg, galleries);

const sortByFilename = (a: ImageMetadata, b: ImageMetadata) => {
  // Extract the numeric part from the filename (e.g., '01' from '01.jpg')
  const numA = parseInt(a.src.match(/(\d+)/)?.[0] || "0", 10);
  const numB = parseInt(b.src.match(/(\d+)/)?.[0] || "0", 10);
  return numA - numB;
};
const sortedImages = images.sort(sortByFilename);
const gallerySchema = buildImageGallerySchema(
  title,
  Astro.url.pathname,
  sortedImages.length,
);
let getDimensions = (i: number, galleryType: GalleryType, total: number) => {
  let mod;
  let isLandscape;
  let classes;
  const isLast = i === total - 1;
  switch (galleryType) {
    case GalleryType.Maternity:
    case GalleryType.Newborn:
    case GalleryType.Milestone:
    case GalleryType.CakeSmash:
    case GalleryType.Family:
    case GalleryType.Children:
    case GalleryType.Branding:
      mod = i % 4;
      isLandscape = mod == 0 || mod == 3;
      // If last image would leave a gap, span remaining columns
      if (isLast && mod == 1) {
        // Only 1 portrait after a landscape row — span all 3
        classes = "xs:col-span-3 col-span-1";
        isLandscape = true;
      } else if (isLast && mod == 2) {
        // 2 items in second row (portrait + this) — make this span 2
        classes = "xs:col-span-2 col-span-1";
        isLandscape = true;
      } else {
        classes = `${isLandscape ? "xs:col-span-2" : "xs:col-span-1"} col-span-1`;
      }
      break;
    case GalleryType.Headshots:
      mod = i % 15;
      isLandscape = mod == 4 || mod == 5 || mod == 13;
      classes = `${isLandscape ? "xs:col-span-2" : "xs:col-span-1"} col-span-1`;
      break;
  }
  return {
    width: isLandscape ? 730 : 357,
    height: 500,
    classes: classes,
  };
};
---

<Main
  title={`Magnolia Coasts | ${metaTitle}`}
  description={description}
  keywords={keywords}
  extraSchemas={[gallerySchema]}
>
  <section
    aria-label={`${title} gallery navigation`}
    class={`self-center ${desktopDisplay} ${mobileDisplay}`}
  >
    <SiblingPackageNav
      text={pkgs[0][0]}
      href={pkgs[0][1]}
      direction={NavDir.Left}
    />
    <SectionHeader title={title} />
    <SiblingPackageNav
      text={pkgs[1][0]}
      href={pkgs[1][1]}
      direction={NavDir.Right}
    />
  </section>
  <p
    class="font-cormorant-garamond max-w-[800px] self-center px-6 py-4 text-center text-lg text-gray-700"
  >
    {galleryIntro[galleryType].text}
    {
      galleryIntro[galleryType].cta && (
        <a
          href={galleryIntro[galleryType].cta![1]}
          class="text-dark-green ml-1 font-semibold underline decoration-1 underline-offset-2 hover:text-green-900"
        >
          {galleryIntro[galleryType].cta![0]} &rarr;
        </a>
      )
    }
  </p>
  <section
    aria-label={`${title} photos`}
    class=`xs:grid-cols-3 grid grid-cols-1 gap-4 self-center p-4 lg:max-w-[1200px]`
  >
    {
      sortedImages.map((image: ImageMetadata, i) => {
        const { width, height, classes } = getDimensions(
          i,
          galleryType,
          sortedImages.length,
        );
        return (
          <figure id={`image-${i}`} class={classes}>
            <Image
              style="content-visibility: auto"
              src={image}
              layout="full-width"
              width={width}
              height={height}
              class="h-[100%] object-cover object-center"
              alt={`${title} photography – photo ${i + 1}`}
              decoding="async"
              loading={i < 6 ? "eager" : "lazy"}
            />
            <figcaption class="sr-only">{`${title} photo ${i + 1}`}</figcaption>
          </figure>
        );
      })
    }
  </section>
  {
    galleryIntro[galleryType].cta && (
      <FloatingCta
        client:idle
        href={galleryIntro[galleryType].cta![1]}
        label={galleryIntro[galleryType].cta![0]}
      />
    )
  }
</Main>
